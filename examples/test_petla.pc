# Test petli dopoki

niech counter: Calk = 0

dopoki counter < 5:
    wypisz(counter)
    counter = counter + 1

# petla z warunkiem logicznym
niech a: Calk = 0
niech b: Calk = 10

dopoki (a < b) i (a < 3):
    wypisz(a)
    a = a + 1

# petla zliczajaca w dol
niech n: Calk = 5

dopoki n > 0:
    wypisz(n)
    n = n - 1
